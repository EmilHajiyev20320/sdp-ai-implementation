# Copy to .env — cp .env.example .env (Unix) or copy .env.example .env (Windows)

# --- Local Firestore emulator (recommended for dev) ---
USE_FIRESTORE_EMULATOR=1
FIRESTORE_EMULATOR_HOST=127.0.0.1:8082
GOOGLE_CLOUD_PROJECT=demo-no-project

# --- GCP production: omit USE_FIRESTORE_EMULATOR; set real project ---
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# --- AI: Gemini (default when API key or Vertex is set) or Ollama + NLLB ---
# auto | gemini | ollama
AI_BACKEND=gemini

# Google AI Studio (local / simple deploy)
GEMINI_API_KEY=AIzaSyDTEZWMwCue8_eaPEf2pGBJYqqpX0mPONg
# Optional override; if unset, the client tries gemini-2.5-flash then other ids on 404.
GEMINI_MODEL=gemini-2.5-flash

# Vertex AI on GCP (Cloud Run — use service account, no API key)
GEMINI_USE_VERTEX=1
GEMINI_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# Local Ollama (when AI_BACKEND=ollama or auto without Gemini)
# OLLAMA_URL=http://127.0.0.1:11434/api/generate
# OLLAMA_MODEL=llama3.2:3b

NEWSDATA_API_KEY=pub_ffe3b52116d9430b9fcb64bdae4476fc

# Optional: article length (defaults 350–750) and expand retries
# ARTICLE_MIN_WORDS=350
# ARTICLE_MAX_WORDS=750
# ARTICLE_EXPAND_ATTEMPTS=4
